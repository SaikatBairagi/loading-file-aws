{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3SendMessage",
      "Effect": "Allow",
      "Principal": { "Service": "s3.amazonaws.com" },
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:us-east-1:468776779868:Spring-boot-listen-Q",
      "Condition": {
        "ArnEquals": {
          "aws:SourceArn": "arn:aws:s3:::saikat-video-upload-bucket"
        }
      }
    }
  ]
}